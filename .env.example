# Cloud Identity Wallet Configuration
# Copy this file to .env and adjust values as needed

# Server Configuration
# Format: APP_<SECTION>__<KEY>
APP_SERVER__HOST=127.0.0.1
APP_SERVER__PORT=3000

# OID4VC (OpenID for Verifiable Credentials) Configuration
# Shared settings for both issuance (OID4VCI) and presentation (OID4VP) flows
APP_OID4VC__CLIENT_ID=cloud-identity-wallet
APP_OID4VC__REDIRECT_URI=http://localhost:3000/api/v1/issuance/callback
APP_OID4VC__USE_SYSTEM_PROXY=true
APP_OID4VC__PREFERRED_DISPLAY_LOCALES=en
APP_OID4VC__REVOCATION_POLICY=soft_fail

# Discovery mode for presentation flow: "static" or "dynamic"
APP_OID4VC__DISCOVERY_MODE=static

# Root truststore directory containing DER- or PEM-encoded X.509 root CA
# certificates. All certificates must be self-signed CAs. Malformed or
# non-CA certificates cause a hard startup error. If unset, all mdoc/x5c
# verifications will fail closed.
# APP_OID4VC__ROOT_TRUSTSTORE_DIR=/etc/oid4vc/truststore