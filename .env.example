# Cloud Identity Wallet Configuration
# Copy this file to .env and adjust values as needed

# Server Configuration
# Format: APP_<SECTION>__<KEY>
APP_SERVER__HOST=127.0.0.1
APP_SERVER__PORT=3000

# --- Memory backends (default, no external services) ---
# Requires Cargo features: memory,local-kms
# APP_BACKEND=memory

# --- MySQL backend ---
# Requires Cargo features: mysql,redis and either local-kms or aws-kms
# APP_BACKEND=mysql
# APP_DATABASE__URL=mysql://user:pass@localhost:3306/cloud_wallet
# APP_REDIS__URI=redis://localhost:6379?protocol=resp3

# --- PostgreSQL backend ---
# Requires Cargo features: postgres,redis and either local-kms or aws-kms
# APP_BACKEND=postgres
# APP_DATABASE__URL=postgres://user:pass@localhost:5432/cloud_wallet
# APP_REDIS__URI=redis://localhost:6379?protocol=resp3

# --- SQLite backend ---
# Requires Cargo features: sqlite and either local-kms or aws-kms
# APP_BACKEND=sqlite
# APP_DATABASE__URL=sqlite:./data/cloud_wallet.db

# --- KMS Providers ---
# APP_KMS__PROVIDER=local
# APP_KMS__PROVIDER=aws
# APP_KMS__AWS_REGION=us-east-1
# APP_KMS__AWS_KMS_KEY_ID=alias/cloud-wallet-master (optional)

# OID4VC (OpenID for Verifiable Credentials) Configuration
# Shared settings for both issuance (OID4VCI) and presentation (OID4VP) flows
APP_OID4VC__CLIENT_ID=cloud-identity-wallet
APP_OID4VC__REDIRECT_URI=http://localhost:3000/api/v1/issuance/callback
APP_OID4VC__USE_SYSTEM_PROXY=false
APP_OID4VC__PREFERRED_DISPLAY_LOCALES=en,de,fr
APP_OID4VC__REVOCATION_POLICY=soft_fail

# Discovery mode for presentation flow: "static" or "dynamic"
APP_OID4VC__DISCOVERY_MODE=static

# Root truststore directory containing DER- or PEM-encoded X.509 root CA
# certificates. All certificates must be self-signed CAs. Malformed or
# non-CA certificates cause a hard startup error. If unset, all mdoc/x5c
# verifications will fail closed.
# APP_OID4VC__ROOT_TRUSTSTORE_DIR=/etc/oid4vc/truststore
