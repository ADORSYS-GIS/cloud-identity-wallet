
# Cloud Identity Wallet Configuration
# Copy this file to .env and adjust values as needed

# Server Configuration
# Format: APP_<SECTION>__<KEY>
APP_SERVER__HOST=127.0.0.1
APP_SERVER__PORT=3000

# Comma-separated paths to PEM or DER IACA root certificates used to verify mso_mdoc credentials.
APP_OID4VCI__IACA_ROOT_PATHS=./animo-eudi-payments.pem
APP_OID4VCI__X5C_TRUST_ANCHOR_PATHS=./animo-eudi-payments.pem
