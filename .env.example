
# Cloud Identity Wallet Configuration
# Copy this file to .env and adjust values as needed

# Server Configuration
# Format: APP_<SECTION>__<KEY>
APP_SERVER__HOST=127.0.0.1
APP_SERVER__PORT=3000

# --- Memory backends (default, no external services) ---
# Requires Cargo features: memory,local-kms
# APP_BACKEND=memory

# --- MySQL backend ---
# Requires Cargo features: mysql,redis and either local-kms or aws-kms
# APP_BACKEND=mysql
# APP_DATABASE__URL=mysql://user:pass@localhost:3306/cloud_wallet
# APP_REDIS__URI=redis://localhost:6379?protocol=resp3

# --- PostgreSQL backend ---
# Requires Cargo features: postgres,redis and either local-kms or aws-kms
# APP_BACKEND=postgres
# APP_DATABASE__URL=postgres://user:pass@localhost:5432/cloud_wallet
# APP_REDIS__URI=redis://localhost:6379?protocol=resp3

# --- SQLite backend ---
# Requires Cargo features: sqlite and either local-kms or aws-kms
# APP_BACKEND=sqlite
# APP_DATABASE__URL=sqlite:./data/cloud_wallet.db

# --- KMS Providers ---
# APP_KMS__PROVIDER=local
# APP_KMS__PROVIDER=aws
# APP_KMS__AWS_REGION=us-east-1
# APP_KMS__AWS_KMS_KEY_ID=alias/cloud-wallet-master

# --- OpenID4VCI ---
# APP_OID4VCI__CLIENT_ID=cloud-identity-wallet
# APP_OID4VCI__REDIRECT_URI=http://localhost:3000/api/v1/issuance/callback
# APP_OID4VCI__USE_SYSTEM_PROXY=true
# APP_OID4VCI__PREFERRED_DISPLAY_LOCALES=en,fr,de
# APP_OID4VCI__IACA_ROOT_PATHS=/certs/iaca-root.pem
# APP_OID4VCI__REVOCATION_POLICY=soft_fail
